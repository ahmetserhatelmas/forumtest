NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Server-only: used for form submit (insert + file upload). Keep secret.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Comma-separated admin emails (case-insensitive). Required for /admin access.
# Optional single: ADMIN_EMAIL=you@example.com
ADMIN_EMAILS=admin@example.com

# Yeni form bildirimi (Resend: https://resend.com — API key alın)
RESEND_API_KEY=re_xxxxxxxx
# Virgülle birden fazla alıcı
SUBMISSION_NOTIFY_EMAIL=sekreter@example.com
# Gönderen (Resend’de doğrulanmış alan adı veya test için onboarding@resend.dev)
RESEND_FROM="Klinik <onboarding@resend.dev>"
# E-postadaki “panelde aç” linki için kök URL (sonunda / olmasın)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Vercel Cron: günlük keep-alive (Supabase + site). Vercel proje ayarlarında CRON_SECRET oluşturun.
# CRON_SECRET=uzun-rastgele-dize
# İsteğe bağlı: sadece pinglenecek URL (yoksa NEXT_PUBLIC_SITE_URL kullanılır)
# KEEP_WARM_URL=https://form.dromerparildar.com
